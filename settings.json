{
  //JSON
  "json.format.enable": true,

  // COPILOT
  "github.copilot.enable": {
    "*": true,
  },

  // FILES
  "files.trimTrailingWhitespace": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },

  // GOLANG
  "gopls": {
    "ui.semanticTokens": true
  },
  "go.toolsManagement.autoUpdate": true,
  "go.inferGopath": true,
  "go.lintOnSave": "workspace",
  "go.lintTool": "golangci-lint",
  "go.vetOnSave": "workspace",
  "go.coverOnSave": false,
  "go.useLanguageServer": true,
  "go.formatTool": "gofumpt",
  "go.inlayHints.rangeVariableTypes": true,
  "go.buildFlags": [
    "-tags=unit,integration,e2e"
  ],
  "go.testTags": "unit,integration,e2e",
  "[go]": {
    "editor.insertSpaces": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    }
  },

  // DEBUG
  "debug.toolBarLocation": "docked",

  // SECURITY
  "security.workspace.trust.untrustedFiles": "open",

  // EXPLORER
  "explorer.confirmDelete": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  "explorer.autoReveal": false,
  "explorer.confirmDragAndDrop": false,

  // TERMINAL
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontFamily": "JetBrainsMonoNL Nerd Font",
  "terminal.explorerKind": "external",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.cursorStyle": "line",

  // GIT
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.suggestSmartCommit": true,
  "git.enableCommitSigning": true,
  "github-actions.remote-name": "upstream",
  "git.openRepositoryInParentFolders": "never",

  // WORKBENCH
  "workbench.startupEditor": "none",
  "workbench.editor.tabActionLocation": "right",
  "workbench.editor.tabSizing": "shrink",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.settings.editor": "json",
  "workbench.list.smoothScrolling": true,
  "workbench.sideBar.location": "right",

  // VIM
  "vim.leader": "<Space>",
  "vim.smartRelativeLine": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.normalModeKeyBindings": [
    // jump between buffers
    { "before": ["<S-h>"], "commands": [":bprevious"]},
    { "before": ["<S-l>"], "commands":[":bnext"]},
    // split windows
    { "before": ["leader","v"], "commands": [":vsplit"]},
    { "before": ["leader","s"], "commands": [":split"]},
    // move between panes
    { "before": ["leader", "h"], "commands":["workbench.action.focusLeftGroup"]},
    { "before": ["leader", "j"], "commands":["workbench.action.focusBelowGroup"]},
    { "before": ["leader", "k"], "commands":["workbench.action.focusAboveGroup"]},
    { "before": ["leader", "l"], "commands":["workbench.action.focusRightGroup"]},
    // NICE TO HAVE
    { "before": ["leader", "q"], "commands": [":q!"] },
    { "before": ["leader", "w"], "commands": [":w!"] },
    { "before": ["leader", "x"], "commands": [":x!"] },
    { "before": ["[", "d"], "commands": ["editor.action.marker.prev"]},
    { "before": ["]", "d"], "commands": ["editor.action.marker.next"]},
    { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"]},
    { "before": ["leader", "p"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["leader", "f"], "commands": ["editor.action.formatDocument"] },
    { "before": ["g", "h"], "commands": ["editor.action.showDefinitionPreviewHover"]}
  ],
    "vim.visualModeKeyBindings": [
    // Stay in visual mode while indenting
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    // Move selected lines while staying in visual mode
    { "before": ["J"], "commands": ["editor.action.moveLinesDownAction"] },
    { "before": ["K"], "commands": ["editor.action.moveLinesUpAction"] },
    // toggle comment selection
    { "before": ["leader", "c"], "commands": ["editor.action.commentLine"] }
  ],

  // ZENMODE
  "zenMode.hideLineNumbers": false,

  // EDITOR
  "editor.suggest.insertMode": "replace",
  "editor.linkedEditing": true,
  "editor.lineHeight": 22,
  "editor.fontLigatures": true,
  "editor.inlayHints.fontFamily": "JetBrainsMonoNL Nerd Font",
  "editor.fontFamily": "JetBrainsMonoNL Nerd Font",
  "editor.fontWeight": "normal",
  "editor.tabSize": 2,
  "editor.indentSize": 2,
  "editor.inlayHints.enabled": "on",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },
  "editor.fontSize": 22,
  "editor.smoothScrolling": false,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.accessibilitySupport": "off",
  "editor.minimap.enabled": false,

  // CUSTOMIZATION
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "meta.function-call.generic.python",
        "settings": {
          "foreground": "#DCDCAA"
        }
      }
    ]
  },
  "workbench.colorTheme": "Catppuccin Mocha",
  "indentRainbow.colors": [
    "#f5c2e722",
    "#cba6f722",
    "#f38ba822",
    "#fab38722",
    "#f9e2af22",
    "#a6e3a122",
    "#94e2d522",
    "#89dceb22",
    "#74c7ec22",
    "#89b4fa22"
  ],
  "workbench.colorCustomizations": {
    "editorBracketHighlight.foreground2": "#B3E1A7",
    "editorBracketHighlight.unexpectedBracket.foreground": "#E48FA8",
    "editorBracketHighlight.foreground1": "#EFB68E",
    "editorBracketHighlight.foreground4": "#C5A7F2",
    "editorBracketHighlight.foreground3": "#F5E3B5"
  },
  "workbench.iconTheme": "material-icon-theme",
  "window.zoomLevel": 0.5,
  "window.dialogStyle": "custom",
  "extensions.ignoreRecommendations": true,
  "redhat.telemetry.enabled": false,
  "breadcrumbs.enabled": false,
}