{
  // COPILOT
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": "true",
  },
  // FILES
  "files.trimTrailingWhitespace": true,
  "files.autoSave": "onWindowChange",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  // GOLANG
  "gopls": {
    "ui.semanticTokens": true
  },
  "go.toolsManagement.autoUpdate": true,
  "go.inferGopath": true,
  "go.lintOnSave": "workspace",
  "go.lintTool": "golangci-lint",
  "go.vetOnSave": "workspace",
  "go.coverOnSave": false,
  "go.useLanguageServer": true,
  "go.formatTool": "gofumpt",
  "go.inlayHints.rangeVariableTypes": true,
  "go.buildFlags": [
    "-tags=unit,integration,e2e"
  ],
  "go.testTags": "unit,integration,e2e",
  "[go]": {
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    }
  },
  // PYTHON
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    },
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "ruff.organizeImports": true,
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "python3",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "standard",
  // JSON
  "json.format.enable": true,
  // DEBUG
  "debug.toolBarLocation": "docked",
  // SECURITY
  "security.workspace.trust.untrustedFiles": "open",
  // EXPLORER
  "explorer.confirmDelete": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  "explorer.autoReveal": false,
  "explorer.confirmDragAndDrop": false,
  // TERMINAL
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontFamily": "JetBrainsMonoNL Nerd Font",
  "terminal.explorerKind": "external",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.cursorStyle": "line",
  // GIT
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.suggestSmartCommit": true,
  "git.enableCommitSigning": true,
  "github-actions.remote-name": "upstream",
  "git.openRepositoryInParentFolders": "never",
  // WORKBENCH
  "workbench.startupEditor": "none",
  "workbench.editor.tabActionLocation": "right",
  "workbench.editor.tabSizing": "shrink",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.settings.editor": "json",
  "workbench.list.smoothScrolling": true,
  "workbench.sideBar.location": "right",
  // VIM
  "vim.leader": "<space>",
  "vim.smartRelativeLine": true,
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<C-n>"
      ],
      "commands": [
        ":nohl"
      ]
    },
  ],
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  // EDITOR
  "editor.lineHeight": 22,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "phase",
  "editor.inlayHints.fontFamily": "JetBrainsMonoNL Nerd Font",
  "editor.fontFamily": "JetBrainsMonoNL Nerd Font",
  "editor.fontWeight": "normal",
  "editor.tabSize": 2,
  "editor.indentSize": 2,
  "editor.detectIndentation": false,
  "editor.inlayHints.enabled": "on",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },
  "editor.formatOnSave": true,
  "editor.fontSize": 20,
  "editor.linkedEditing": false,
  "editor.smoothScrolling": false,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.accessibilitySupport": "off",
  "editor.minimap.enabled": false,
  // CUSTOMIZATION
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "meta.function-call.generic.python",
        "settings": {
          "foreground": "#DCDCAA"
        }
      }
    ]
  },
  "workbench.colorTheme": "Catppuccin Mocha",
  "indentRainbow.colors": [
    "#f5c2e722",
    "#cba6f722",
    "#f38ba822",
    "#fab38722",
    "#f9e2af22",
    "#a6e3a122",
    "#94e2d522",
    "#89dceb22",
    "#74c7ec22",
    "#89b4fa22"
  ],
  "workbench.colorCustomizations": {
    "editorBracketHighlight.foreground2": "#B3E1A7",
    "editorBracketHighlight.unexpectedBracket.foreground": "#E48FA8",
    "editorBracketHighlight.foreground1": "#EFB68E",
    "editorBracketHighlight.foreground4": "#C5A7F2",
    "editorBracketHighlight.foreground3": "#F5E3B5"
  },
  "window.zoomLevel": -1,
  "window.dialogStyle": "custom",
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.toml": "properties"
  },
  "redhat.telemetry.enabled": false,
  "githubPullRequests.pullBranch": "never"
}