{
  // FILES
  "files.trimTrailingWhitespace": true,
  "files.autoSave": "onWindowChange",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
  },
  // GOLANG
  "go.inferGopath": true,
  "go.lintOnSave": "package",
  "go.lintTool": "golangci-lint",
  "go.vetOnSave": "package",
  "go.coverOnSave": false,
  "go.useLanguageServer": true,
  "[go]":{
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    }
  },
  // PYTHON
  "ruff.organizeImports": true,
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "python3",
  // JSON
  "json.format.enable": true,
  // DEBUG
  "debug.toolBarLocation": "docked",
  // SECURITY
  "security.workspace.trust.untrustedFiles": "open",
  // EXPLORER
  "explorer.confirmDelete": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  "explorer.autoReveal": false,
  "explorer.confirmDragAndDrop": false,
  // TERMINAL
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontFamily": "JetBrainsMonoNL Nerd Font",
  "terminal.explorerKind": "external",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.cursorStyle": "line",
  // GIT
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.suggestSmartCommit": true,
  "git.enableCommitSigning": true,
  "github-actions.remote-name": "upstream",
  "git.openRepositoryInParentFolders": "never",
  // WORKBENCH
  "workbench.editor.tabActionLocation": "right",
  "workbench.editor.tabSizing": "shrink",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.settings.editor": "json",
  "workbench.list.smoothScrolling": true,
  "workbench.sideBar.location": "right",
  // VIM
  "vim.smartRelativeLine": true,
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"]
    },
    {
      "before": ["<C-n>"],
      "commands": [":nohl"]
    },
    {
      "before": ["K"],
      "commands": ["lineBreakInsert"],
      "silent": true
    }
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  // EDITOR
  "editor.lineHeight": 22,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "phase",
  "editor.inlayHints.fontFamily": "JetBrainsMonoNL Nerd Font",
  "editor.fontFamily": "JetBrainsMonoNL Nerd Font",
  "editor.fontWeight": "normal",
  "editor.tabSize": 2,
  "editor.inlayHints.enabled":"on",
  // "editor.formatOnSave": true,
  "editor.fontSize": 15,
  "editor.linkedEditing": false,
  "editor.smoothScrolling": false,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.accessibilitySupport": "off",
  // CUSTOMIZATION
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "meta.function-call.generic.python",
        "settings": {
          "foreground": "#DCDCAA"
        },
      }
    ]
  },
  "workbench.colorTheme": "Catppuccin Mocha",
  "indentRainbow.colors": [
    "#f5c2e722",
    "#cba6f722",
    "#f38ba822",
    "#fab38722",
    "#f9e2af22",
    "#a6e3a122",
    "#94e2d522",
    "#89dceb22",
    "#74c7ec22",
    "#89b4fa22",
  ],
  "workbench.colorCustomizations": {
    "editorBracketHighlight.foreground2": "#B3E1A7",
    "editorBracketHighlight.unexpectedBracket.foreground": "#E48FA8",
    "editorBracketHighlight.foreground1": "#EFB68E",
    "editorBracketHighlight.foreground4": "#C5A7F2",
    "editorBracketHighlight.foreground3": "#F5E3B5",
  },
  "window.zoomLevel": -2,
  "window.dialogStyle": "custom",
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
},
"extensions.ignoreRecommendations": true,
"files.associations": {
  "*.toml": "properties"
},
"workbench.startupEditor": "none",
}